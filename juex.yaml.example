# Copy this template to .juex/juex.yaml in the project you want juex to run in.
# The .juex directory is local runtime state and should not be committed.
provider:
  # Known presets: openai, openai-codex, anthropic.
  # Known presets fix the protocol and default base URL. Do not combine a
  # known id with a different protocol; omit id for custom providers.
  # id: openai
  #
  # For OpenAI Codex OAuth, use:
  # id: openai-codex
  # model: gpt-5.5
  #
  # For an unknown or OpenAI-compatible provider, omit id and set protocol.
  # Valid custom protocol values: anthropic/messages, openai/responses,
  # openai/chat.
  # protocol: openai/chat
  #
  # A config layer with id or protocol starts a new provider profile. Repeat
  # provider-specific values in that layer or set them with environment vars.
  #
  # Known providers usually leave base_url empty. Custom providers must set it.
  id: openai
  base_url: ""
  api_key: ""
  model: ""
  # Optional: control reasoning depth for thinking models.
  # Valid values: "low", "medium", "high". Omit to use the provider default.
  # thinking_effort: ""
  # Optional: provider context window in tokens. Defaults to 256000.
  # context_window: 256000
  # Optional provider-specific HTTP headers and query parameters.
  # headers:
  #   X-Provider-Feature: "1"
  # query:
  #   beta: "1"
  # Optional capability gates. Unsupported features are not sent.
  # capabilities:
  #   tools: true
  #   streaming: false
  #   reasoning_effort: true
  #   reasoning_replay: true
  #   max_output_tokens: true
  # Optional provider compatibility knobs.
  # compat:
  #   reasoning_replay_fields:
  #     - reasoning_content

compaction:
  enabled: true
  reserve_tokens: 16384
  keep_recent_tokens: 20000
  tail_turns: 2
  summary_max_tokens: 2048
  tool_result_max_chars: 2000
