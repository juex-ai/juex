# Prefer `juex init` for first-run setup. Copy this template manually only when
# you want full control over .juex/juex.yaml in a workspace or
# ~/.juex/juex.yaml for user-global provider fallback settings.
# The workspace .juex directory is local runtime state and should not be
# committed.

# Active model, in provider:model form. Override per invocation with
# `juex --model provider:model ...`.
model: openai:gpt-4.1

# User-global resources under ~/.agents and ~/.juex/extensions are enabled by
# default. Set to false or 0 to ignore ~/.agents/AGENTS.md, ~/.agents/skills,
# ~/.agents/mcp.json, and ~/.juex/extensions for this workspace or run.
# enable_user_global_resources: true

# Optional extension bundles live at ~/.juex/extensions/<name> and
# .juex/extensions/<name>. Each bundle may contain skills/<skill>/SKILL.md,
# mcp.json, and hooks.yaml. Work-local extension hooks must set trusted: true
# before Juex executes them.

# Optional skill catalog controls. Juex loads user, extension, and project
# skills into an on-demand catalog, then keeps only a compact budgeted index in
# the system prompt. Models call skill_search and skill_load to inspect the full
# SKILL.md content when needed.
# skills:
#   # prompt_budget_chars: 8000
#   # include: [taskline-management] # whitelist mode; exclude is ignored.
#   # exclude: [large-global-skill]  # blacklist mode when include is empty.

# Optional workspace command shell. Omitted is the same as profile: auto.
# The field is always an object; scalar values like `shell: powershell` are not
# accepted. Built-in profiles are auto, powershell, cmd, bash, zsh, sh,
# git-bash, wsl, and custom. Use custom only when you need to set family, args,
# or path styles yourself.
# shell:
#   profile: auto
#   # binary: pwsh
#   # For profile: custom only:
#   # family: powershell
#   # args: ["-NoProfile", "-Command"]
#   # path_style: windows

# Optional OS-level sandbox for commands started by exec_command. Disabled
# preserves the current in-place execution behavior. When enabled, commands
# must start through a platform sandbox backend or fail closed with an
# actionable error; Juex never silently falls back to unsandboxed execution.
# Workspace files remain read/write. outside_workspace controls filesystem
# access outside the workspace: read_write or read_only. blocked_paths makes
# selected paths inaccessible even when the preset would otherwise allow them.
# Restricted modes may still expose backend-owned device and temporary scratch
# paths that standard shell tools require, without reopening arbitrary host
# paths outside the workspace.
# sandbox:
#   enabled: false
#   file_system:
#     outside_workspace: read_write
#     # Linux command sandboxing fails closed if a blocked path does not
#     # already exist, because missing paths cannot be safely masked.
#     blocked_paths:
#       - ~/.ssh
#       - ~/.aws
#   network:
#     enabled: true

# Optional runtime policy. Durations use Go duration syntax.
# runtime:
#   pending_input_ttl: 15m
#   external_event_ttl: 24h
#   tool_timeout: 60s
#   # Optional normal-turn provider output cap. Omit to use provider default.
#   max_output_tokens: 8192

# Optional lifecycle command hooks. User-global hooks in ~/.juex/juex.yaml are
# trusted by location. Project-local hooks must set trusted: true before Juex
# will execute them.
# hooks:
#   trusted: true
#   commands:
#     - name: add-ticket-context
#       events: [UserPromptSubmit]
#       command: ["printf", "ticket: ABC-123"]
#       # Defaults to 10 and cannot exceed 300.
#       timeout_seconds: 5
#       max_output_bytes: 65536

providers:
  # Known preset provider ids: openai, openai-codex, anthropic, deepseek.
  # Known presets fix the protocol and default base URL. Custom providers must
  # use their own id and set protocol explicitly.
  - id: openai
    # Valid custom protocol values: anthropic/messages, openai/responses,
    # openai/chat. Leave empty for known presets.
    # protocol: openai/chat
    #
    # Known providers usually leave base_url empty. Custom providers must set it.
    base_url: ""
    api_key: ""
    # Optional provider-specific HTTP headers and query parameters.
    # headers:
    #   X-Provider-Feature: "1"
    # query:
    #   beta: "1"
    # Optional capability gates. Unsupported features are not sent.
    # capabilities:
    #   tools: true
    #   vision: false
    #   streaming: false
    #   reasoning_effort: true
    #   reasoning_replay: true
    #   max_output_tokens: true
    # Optional provider compatibility knobs.
    # compat:
    #   reasoning_replay_fields:
    #     - reasoning_content
    #   # openai-codex only: sse (default), auto, websocket, or websocket-cached.
    #   codex_transport: sse
    models:
      - id: gpt-4.1
        # Optional: control reasoning depth for thinking models.
        # Valid values: "low", "medium", "high", "xhigh", "max".
        # Omit to use the provider default.
        # thinking_effort: ""
        # Optional: model context window in tokens. Defaults to 256000.
        # context_window: 256000

  # DeepSeek uses OpenAI-compatible Chat Completions, with reasoning_effort
  # enabled by default and reasoning_content replayed across tool turns.
  # - id: deepseek
  #   api_key: ""
  #   models:
  #     - id: deepseek-v4-pro

  # For OpenAI Codex OAuth, switch the top-level model to
  # openai-codex:gpt-5.5 and use:
  # - id: openai-codex
  #   # Optional: try Codex-style WebSocket cached transport.
  #   # compat:
  #   #   codex_transport: auto
  #   models:
  #     - id: gpt-5.5

compaction:
  enabled: true
  reserve_tokens: 16384
  keep_recent_tokens: 20000
  tail_turns: 2
  summary_max_tokens: 2048
  tool_result_max_chars: 2000
  user_input_inline_max_bytes: 65536
  user_input_preview_head_bytes: 8192
  user_input_preview_tail_bytes: 8192
  tool_result_inline_max_bytes: 32768
  tool_result_preview_head_bytes: 8192
  tool_result_preview_tail_bytes: 8192
  max_auto_failures: 3
